APP_NAME=banking-platform
ENV=local

DATABASE_URL=postgresql://user:password@localhost:5432/banking
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=change_me

# SMTP (for OTP email delivery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@adxbank.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=noreply@adxbank.com
SMTP_FROM_NAME=ADX Bank

# Frontend URL (used in password reset email links)
FRONTEND_URL=http://localhost:3000
