# ──────────────────────────────────────────────
# ADX Bank — Environment Variables Template
# Copy this file to .env and fill in your values
# cp .env.example .env
# ──────────────────────────────────────────────

APP_NAME=banking-platform
ENV=local

# ── Database ───────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/banking

# ── Redis ──────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ───────────────────────────────────
# Use a long random string — e.g.: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret-string

# ── SMTP (OTP + email delivery) ────────────────
# Gmail: Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=your@gmail.com
SMTP_FROM_NAME=ADX Bank

# ── Frontend ───────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── AI Provider Priority ────────────────────────
# Comma-separated, left = highest priority. Auto-fallback on failure.
# Available: groq, openai, claude
AI_PROVIDER_PRIORITY=groq,openai,claude

# ── Groq (FREE — console.groq.com → API Keys) ──
GROQ_API_KEY=gsk_your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ── OpenAI / ChatGPT (paid — platform.openai.com) ──
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic / Claude (console.anthropic.com) ──
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
CLAUDE_MODEL=claude-haiku-4-5-20251001
